<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ report_title }} — {{ frequency }} DNS Report</title>
<style>
/* ── Page setup (WeasyPrint CSS Paged Media) ──────────────────────────── */
@page {
  size: A4;
  margin: 1.8cm 1.5cm 2.2cm 1.5cm;
  @bottom-center {
    content: "Page " counter(page) " of " counter(pages);
    font-size: 8pt;
    color: #999999;
    font-family: -apple-system, Arial, sans-serif;
  }
  @bottom-right {
    content: "{{ generated_at }}";
    font-size: 8pt;
    color: #999999;
    font-family: -apple-system, Arial, sans-serif;
  }
}

/* ── Reset & base ─────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
  font-size: 10pt;
  color: #1a1a1a;
  background: #ffffff;
  line-height: 1.5;
}
h1, h2, h3 { font-weight: 700; line-height: 1.2; }
a { color: #2E6DA4; text-decoration: none; }
img { max-width: 100%; display: block; }

/* ── Header banner ────────────────────────────────────────────────────── */
.report-header {
  background: #722F37;
  color: #ffffff;
  padding: 24px 28px 20px;
  margin-bottom: 0;
  page-break-inside: avoid;
}
.report-header .brand {
  font-size: 9pt;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  opacity: 0.75;
  margin-bottom: 6px;
}
.report-header h1 {
  font-size: 22pt;
  margin-bottom: 6px;
}
.report-header .meta {
  font-size: 9pt;
  opacity: 0.85;
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  margin-top: 8px;
}
.report-header .meta span::before {
  content: "▸ ";
  opacity: 0.6;
}
.badge {
  display: inline-block;
  background: rgba(255,255,255,0.18);
  border: 1px solid rgba(255,255,255,0.35);
  border-radius: 12px;
  padding: 2px 10px;
  font-size: 8pt;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-top: 10px;
}

/* ── Period bar ───────────────────────────────────────────────────────── */
.period-bar {
  background: #4A1E24;
  color: rgba(255,255,255,0.85);
  padding: 7px 28px;
  font-size: 8.5pt;
  display: flex;
  justify-content: space-between;
}

/* ── Content wrapper ──────────────────────────────────────────────────── */
.content { padding: 20px 0 0; }

/* ── Section titles ───────────────────────────────────────────────────── */
.section {
  margin-bottom: 22px;
  page-break-inside: avoid;
}
.section-title {
  font-size: 11pt;
  font-weight: 700;
  color: #722F37;
  border-bottom: 2px solid #722F37;
  padding-bottom: 4px;
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* ── Summary cards ────────────────────────────────────────────────────── */
.cards {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 22px;
}
.card {
  flex: 1;
  min-width: 100px;
  background: #f8f5f6;
  border-left: 4px solid #722F37;
  border-radius: 3px;
  padding: 12px 14px;
}
.card.blue  { border-left-color: #2E6DA4; }
.card.green { border-left-color: #2D7D46; }
.card.amber { border-left-color: #D97706; }
.card.red   { border-left-color: #C0392B; }
.card-value {
  font-size: 20pt;
  font-weight: 700;
  color: #722F37;
  line-height: 1;
  margin-bottom: 4px;
}
.card.blue  .card-value { color: #2E6DA4; }
.card.green .card-value { color: #2D7D46; }
.card.amber .card-value { color: #D97706; }
.card.red   .card-value { color: #C0392B; }
.card-label {
  font-size: 7.5pt;
  color: #888888;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* ── Chart grid ───────────────────────────────────────────────────────── */
.chart-row {
  display: flex;
  gap: 14px;
  margin-bottom: 18px;
  page-break-inside: avoid;
}
.chart-half {
  flex: 1;
  min-width: 0;
}
.chart-full {
  width: 100%;
  page-break-inside: avoid;
}
.chart-img {
  width: 100%;
  border-radius: 4px;
  border: 1px solid #e5d7d9;
}

/* ── Tables ───────────────────────────────────────────────────────────── */
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 8.5pt;
}
thead th {
  background: #722F37;
  color: #ffffff;
  padding: 7px 10px;
  text-align: left;
  font-weight: 600;
  font-size: 7.5pt;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}
tbody tr:nth-child(even) { background: #fdf9f9; }
tbody tr:hover { background: #f5ecec; }
tbody td {
  padding: 6px 10px;
  border-bottom: 1px solid #f0e8e9;
  vertical-align: middle;
}
tbody td.mono {
  font-family: "SFMono-Regular", "Consolas", "Menlo", monospace;
  font-size: 7.5pt;
  color: #333333;
}
.tbl-wrap {
  overflow: hidden;
  border: 1px solid #e5d7d9;
  border-radius: 4px;
}

/* ── Status pills ─────────────────────────────────────────────────────── */
.pill {
  display: inline-block;
  padding: 2px 9px;
  border-radius: 10px;
  font-size: 7pt;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}
.pill-green  { background: #d1f0de; color: #1a5c32; }
.pill-red    { background: #fce8e8; color: #7b1c1c; }
.pill-amber  { background: #fef3d0; color: #7a4a00; }
.pill-blue   { background: #ddeeff; color: #1a3d6e; }
.pill-gray   { background: #f0f0f0; color: #555555; }

/* ── DNSSEC status block ──────────────────────────────────────────────── */
.dnssec-block {
  border: 1px solid #e5d7d9;
  border-radius: 4px;
  padding: 14px 18px;
  background: #fdf9f9;
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.dnssec-indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  margin-top: 3px;
  flex-shrink: 0;
}
.dnssec-indicator.active   { background: #2D7D46; }
.dnssec-indicator.inactive { background: #C0392B; }
.dnssec-indicator.unknown  { background: #D97706; }
.dnssec-body h3 { font-size: 10pt; margin-bottom: 4px; }
.dnssec-body p  { font-size: 8pt; color: #666; margin: 2px 0 0; }

/* ── Record type summary inline table ────────────────────────────────── */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}
.type-chip {
  background: #f0eced;
  border: 1px solid #ddd0d2;
  border-radius: 4px;
  padding: 4px 10px;
  font-size: 8pt;
  font-weight: 600;
}
.type-chip span {
  color: #722F37;
}

/* ── Footer ───────────────────────────────────────────────────────────── */
.report-footer {
  margin-top: 28px;
  border-top: 2px solid #e5d7d9;
  padding-top: 10px;
  font-size: 7.5pt;
  color: #aaaaaa;
  display: flex;
  justify-content: space-between;
}

/* ── Utility ──────────────────────────────────────────────────────────── */
.text-right { text-align: right; }
.text-center { text-align: center; }
.nowrap { white-space: nowrap; }
.proxied-yes { color: #F6821F; font-weight: 600; }
.proxied-no  { color: #888888; }
.page-break  { page-break-before: always; }
</style>
</head>
<body>

{# ═══════════════════════════════════════════════════════ HEADER ═══ #}
<div class="report-header">
  <div class="brand">Cloudflare Website &amp; DNS Report</div>
  <h1>{{ report_title }}</h1>
  <div class="meta">
    <span>{{ zone_info.name | default(zone.zone_name) }}</span>
    <span>{{ frequency }} Report</span>
  </div>
  <div class="badge">{{ frequency }}</div>
</div>

<div class="period-bar">
  <span>Report Period: {{ period.start }} — {{ period.end }}</span>
  <span>Generated: {{ generated_at }}</span>
</div>

<div class="content">

{# ═══════════════════════════════════════════════════ SUMMARY CARDS ═ #}
{# Compute totals needed for cards #}
{% set ns = namespace(blocked=0) %}
{% for row in http_security.get('securityByAction', []) %}
  {% if row.dimensions.action in ['block', 'managed_challenge', 'challenge', 'jschallenge'] %}
    {% set ns.blocked = ns.blocked + row.count %}
  {% endif %}
{% endfor %}

<div class="section">
  <div class="section-title">At a Glance</div>
  <div class="cards">

    <div class="card">
      <div class="card-value">{{ metrics.total_queries | human }}</div>
      <div class="card-label">DNS Lookups</div>
    </div>

    {% if http_totals %}
    <div class="card blue">
      <div class="card-value">{{ http_totals.uniq.uniques | human }}</div>
      <div class="card-label">Unique Visitors</div>
    </div>

    <div class="card blue">
      <div class="card-value">{{ http_totals.sum.visits | human }}</div>
      <div class="card-label">Total Visits</div>
    </div>
    {% endif %}

    {% if ns.blocked > 0 %}
    <div class="card red">
      <div class="card-value">{{ ns.blocked | human }}</div>
      <div class="card-label">Threats Blocked</div>
    </div>
    {% endif %}

    <div class="card green">
      <div class="card-value">{{ metrics.success_pct | pct }}</div>
      <div class="card-label">Resolution Success</div>
    </div>

    <div class="card blue">
      <div class="card-value">{{ metrics.cache_hit_pct | pct }}</div>
      <div class="card-label">Cache Performance</div>
    </div>

    {% if http_totals and http_totals.sum.edgeResponseBytes %}
    <div class="card">
      <div class="card-value">{{ human_bytes(http_totals.sum.edgeResponseBytes) }}</div>
      <div class="card-label">Bandwidth Served</div>
    </div>
    {% endif %}

  </div>
</div>

{# ═══════════════════════════════════════════════ QUERY VOLUME CHART ═ #}
{% if charts.volume %}
<div class="section">
  <div class="section-title">DNS Activity Over Time</div>
  <div class="chart-full">
    <img class="chart-img" src="data:image/png;base64,{{ charts.volume }}" alt="DNS Activity Over Time">
  </div>
</div>
{% endif %}

{# ════════════════════════════════════ TRAFFIC & GEOGRAPHY (2-up) ════ #}
{% if charts.countries or charts.colo %}
<div class="section">
  <div class="section-title">Traffic &amp; Geography</div>
  <div class="chart-row">
    {% if charts.countries %}
    <div class="chart-half">
      <img class="chart-img" src="data:image/png;base64,{{ charts.countries }}" alt="Top Countries by Traffic">
    </div>
    {% endif %}
    {% if charts.colo %}
    <div class="chart-half">
      <img class="chart-img" src="data:image/png;base64,{{ charts.colo }}" alt="DNS Queries by Data Center">
    </div>
    {% endif %}
  </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════ TOP DOMAINS CHART ═══ #}
{% if charts.domains %}
<div class="section">
  <div class="section-title">Most Active Services &amp; Domains</div>
  <div class="chart-full">
    <img class="chart-img" src="data:image/png;base64,{{ charts.domains }}" alt="Most Active Services">
  </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════ SECURITY EVENTS ═════ #}
{% set sec_events = http_security.get('securityByAction', []) %}
{% if sec_events %}
<div class="section">
  <div class="section-title">Security Events</div>
  {% set action_labels = {
    'block':              ('Blocked',                  'pill-red',   'Traffic stopped before reaching your website — triggered by firewall or WAF rules.'),
    'managed_challenge':  ('Challenged (Turnstile)',   'pill-amber', 'Visitors presented an invisible or interactive challenge to prove they are human.'),
    'challenge':          ('Challenged (CAPTCHA)',     'pill-amber', 'Legacy CAPTCHA challenge presented to the visitor.'),
    'jschallenge':        ('JS Challenge',             'pill-amber', 'Browser integrity check used to filter automated bots.'),
    'log':                ('Logged / Monitored',       'pill-blue',  'Request matched a rule in monitor-only mode — no action taken, recorded for review.'),
    'allow':              ('Explicitly Allowed',       'pill-green', 'Request matched an allow rule and bypassed further security checks.'),
    'bypass':             ('Rule Bypass',              'pill-gray',  'Request bypassed one or more security features due to a bypass rule.'),
  } %}
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th style="width:22%;">Action Taken</th>
          <th class="text-right" style="width:14%;">Events</th>
          <th>What This Means</th>
        </tr>
      </thead>
      <tbody>
        {% for row in sec_events %}
        {% set action = row.dimensions.action %}
        {% set info = action_labels.get(action, (action | title, 'pill-gray', '')) %}
        <tr>
          <td><span class="pill {{ info[1] }}">{{ info[0] }}</span></td>
          <td class="text-right"><strong>{{ row.count | human }}</strong></td>
          <td style="color:#555; font-size:8pt;">{{ info[2] }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

{# ═══════════════════════════════════════════════════ DNSSEC STATUS ═══ #}
<div class="section">
  <div class="section-title">DNS Security (DNSSEC)</div>
  {% set ds = dnssec %}
  {% set dnssec_status = ds.status | lower if ds.status else 'unknown' %}
  <div class="dnssec-block">
    <div class="dnssec-indicator {{ 'active' if dnssec_status == 'active' else ('inactive' if dnssec_status in ['disabled', 'inactive'] else 'unknown') }}"></div>
    <div class="dnssec-body">
      <h3>
        {% if dnssec_status == 'active' %}
          DNS Tampering Protection: Active
        {% elif dnssec_status in ['disabled', 'inactive'] %}
          DNS Tampering Protection: Not Enabled
        {% else %}
          DNS Tampering Protection: {{ ds.status | default('Unknown') }}
        {% endif %}
      </h3>
      {% if ds.status == 'active' %}
      <p>DNSSEC is active. DNS responses for this domain are cryptographically signed, preventing attackers from redirecting visitors to malicious sites through DNS hijacking or cache poisoning.</p>
      {% elif dnssec_status in ['disabled', 'inactive'] %}
      <p>DNSSEC is not currently enabled. Enabling it protects visitors from being redirected to fake or malicious versions of your website without their knowledge. This is a recommended security measure.</p>
      {% endif %}
      {% if ds.modified_on %}
      <p style="color:#888; font-size:8pt;">Last updated: {{ ds.modified_on[:10] }}</p>
      {% endif %}
    </div>
  </div>
</div>

{# ═══════════════════════════════════════════════ DNS CONFIGURATION ════ #}
{% if dns_records %}
<div class="section">
  <div class="section-title">DNS Configuration Summary</div>
  <p style="color:#555; font-size:9pt; margin-bottom:10px;">
    {{ dns_records | length }} DNS record{{ 's' if dns_records | length != 1 }} configured for this domain.
    {% set proxied_count = dns_records | selectattr('proxied', 'equalto', true) | list | length %}
    {% if proxied_count > 0 %}
    {{ proxied_count }} record{{ 's' if proxied_count != 1 }} are routed through Cloudflare's network for added performance and protection.
    {% endif %}
  </p>
  <div class="type-grid">
    {% for rtype, count in metrics.record_type_counts.items() %}
    <div class="type-chip"><span>{{ rtype }}</span> × {{ count }}</div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ════════════════════════════════════════════════════════ FOOTER ════ #}
<div class="report-footer">
  <span>
    {{ zone_info.name | default(zone.zone_name) }} &bull;
    {{ frequency }} DNS Report &bull;
    {{ period.start }} to {{ period.end }}
  </span>
  <span>CloudflareDNS-Auto-Report</span>
</div>

</div>{# end .content #}
</body>
</html>
