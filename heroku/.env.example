# ─── Cloudflare API Tokens ────────────────────────────────────────────────────
# Create scoped tokens at https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.DNS (read), Zone.Zone (read), Zone.Analytics (read)
CF_TOKEN_APPLE_JUICE=your_cloudflare_api_token_here
CF_TOKEN_ORANGE_JUICE=your_cloudflare_api_token_here

# ─── SMTP Configuration ───────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=465
SMTP_USERNAME=reports@yourdomain.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=reports@yourdomain.com

# ─── App Configuration ────────────────────────────────────────────────────────
# Path to your accounts config (relative to project root)
ACCOUNTS_CONFIG_PATH=config/accounts.json

# Timezone for log output (report times always use UTC)
TZ=UTC

# Set to "true" to send a test report on startup (for debugging)
SEND_TEST_ON_STARTUP=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
